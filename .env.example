# Plantilla de variables de entorno. Copia este archivo a `.env` y rellena los valores.
# cp .env.example .env

# URL base del backend Go (API).
# Local (SAM local start-api):  http://127.0.0.1:3000
# Producción (AWS API Gateway): https://xxxxx.execute-api.<region>.amazonaws.com
API_URL=

# Secreto para VERIFICAR los JWT que emite el back (HS256).
# DEBE coincidir EXACTAMENTE con el JWT_SECRET del backend (la-michi-pos-api).
JWT_SECRET=
